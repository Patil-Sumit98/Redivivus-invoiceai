# ══════════════════════════════════════════════════
# InvoiceAI — Git Ignore Rules
# ══════════════════════════════════════════════════

# ── Python ──────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg

# ── Virtual Environments ───────────────────────
venv/
.venv/
env/
backend/venv/

# ── IDE ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Environment Variables ──────────────────────
.env
.env.local
.env.*.local
backend/.env
frontend/.env.local

# ── Database Files ─────────────────────────────
*.db
*.sqlite3

# ── Node.js (React frontend) ──────────────────
node_modules/
frontend/node_modules/
frontend/dist/

# ── OS Files ───────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ───────────────────────────────────────
*.log

# ── Temp / Scratch Files ──────────────────────
out.json
out.txt
scaffold.py
test_db.py
test_gst.py
setup_react*.bat
errors.txt
ts_errors.txt
ts_errors.log
commit_msg.txt

# ── Pytest ─────────────────────────────────────
.pytest_cache/